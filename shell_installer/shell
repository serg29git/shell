#!/bin/sh
# shell - universal shell detector
# Usage: shell [-v|--verbose]

# Determine shell by version variables (priority)
if [ -n "$FISH_VERSION" ]; then
    shell="fish"
elif [ -n "$BASH_VERSION" ]; then
    shell="bash"
elif [ -n "$ZSH_VERSION" ]; then
    shell="zsh"
elif [ -n "$KSH_VERSION" ]; then
    shell="ksh"
elif [ -n "$YASH_VERSION" ]; then
    shell="yash"
else
    # Fallback: try to get shell name from parent process
    # (works for dash, sh, tcsh, csh, ash, etc.)
    ppid=$PPID
    parent_cmd=$(ps -p "$ppid" -o comm= 2>/dev/null | head -n1)
    if [ -n "$parent_cmd" ]; then
        shell="$parent_cmd"
    else
        # Last resort: basename of SHELL
        if [ -n "$SHELL" ]; then
            shell=$(basename "$SHELL")
        else
            shell="unknown"
        fi
    fi
fi

# If verbose, show full info
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
    echo "Shell: $shell"
    # Version
    case "$shell" in
        fish)   [ -n "$FISH_VERSION" ] && echo "Version: $FISH_VERSION" ;;
        bash)   [ -n "$BASH_VERSION" ] && echo "Version: $BASH_VERSION" ;;
        zsh)    [ -n "$ZSH_VERSION" ] && echo "Version: $ZSH_VERSION" ;;
        ksh)    [ -n "$KSH_VERSION" ] && echo "Version: $KSH_VERSION" ;;
        yash)   [ -n "$YASH_VERSION" ] && echo "Version: $YASH_VERSION" ;;
    esac
    echo "PID: $$"
    # Executable path (real shell executable)
    case "$shell" in
        fish)   exe=$(command -v fish 2>/dev/null || which fish 2>/dev/null) ;;
        bash)   exe=$(command -v bash 2>/dev/null || which bash 2>/dev/null) ;;
        zsh)    exe=$(command -v zsh 2>/dev/null || which zsh 2>/dev/null) ;;
        ksh)    exe=$(command -v ksh 2>/dev/null || which ksh 2>/dev/null) ;;
        yash)   exe=$(command -v yash 2>/dev/null || which yash 2>/dev/null) ;;
        *)      exe=$(command -v "$shell" 2>/dev/null || which "$shell" 2>/dev/null) ;;
    esac
    [ -n "$exe" ] && echo "Executable: $exe"
    # History availability
    if history 2>/dev/null | tail -n 10 >/dev/null 2>&1; then
        echo "History: available"
    else
        echo "History: not supported"
    fi
else
    echo "$shell"
fi
