#!/bin/sh
# shell - show current shell info
# Usage: shell [-v|--verbose]

# --- get shell ---
if [ -n "$FISH_VERSION" ]; then
    shell="fish"
elif [ -n "$BASH_VERSION" ]; then
    shell="bash"
elif [ -n "$ZSH_VERSION" ]; then
    shell="zsh"
elif [ -n "$KSH_VERSION" ]; then
    shell="ksh"
elif [ -n "$YASH_VERSION" ]; then
    shell="yash"
else
    if [ -n "$SHELL" ]; then
        shell=$(basename "$SHELL")
    else
        shell="unknown"
    fi
fi

# --- get shell version ---
get_version() {
    case "$1" in
        fish)   echo "$FISH_VERSION" ;;
        bash)   echo "$BASH_VERSION" ;;
        zsh)    echo "$ZSH_VERSION" ;;
        ksh)    echo "$KSH_VERSION" ;;
        yash)   echo "$YASH_VERSION" ;;
        *)
            # Пробуем через --version
            if command -v "$1" >/dev/null 2>&1; then
                "$1" --version 2>/dev/null | head -n1 | sed 's/^.*version //; s/ .*//'
            else
                echo "unknown"
            fi
            ;;
    esac
}

# --- check uptime ---
get_uptime() {
    ps -p $$ -o etime= 2>/dev/null | sed 's/^ //'
}

# --- check user ---
get_user() {
    whoami 2>/dev/null || id -un 2>/dev/null || echo "unknown"
}

# --- output ---
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
    echo "Shell: $shell"
    version=$(get_version "$shell")
    [ -n "$version" ] && echo "Version: $version"
    echo "PID: $$"
    echo "User: $(get_user)"
    echo "Uptime: $(get_uptime)"
    if [ -L "/proc/$$/exe" ]; then
        exe=$(readlink -f "/proc/$$/exe" 2>/dev/null)
        [ -n "$exe" ] && echo "Executable: $exe"
    else
        exe=$(ps -p $$ -o args= 2>/dev/null | awk '{print $1}')
        [ -n "$exe" ] && echo "Command: $exe"
    fi
    if history 2>/dev/null | tail -n 10 >/dev/null 2>&1; then
        echo "History: available"
    else
        echo "History: not supported"
    fi
else
    echo "$shell"
fi
